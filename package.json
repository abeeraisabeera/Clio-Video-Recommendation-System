{
  "name": "clio-recommender",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "python app.py",
    "dev:web": "pnpm --filter clio-frontend dev",
    "build": "pnpm --filter clio-frontend build",
    "build:hf": "pnpm --filter clio-frontend build:static",
    "test": "pnpm test:py && pnpm test:web",
    "test:py": "python -m pytest tests/ -q",
    "test:web": "pnpm --filter clio-frontend test",
    "evaluate": "python evaluate.py",
    "lint": "pnpm --filter clio-frontend lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
